{
  "name": "luxes-backend",
  "version": "1.0.0",
  "description": "Backend API de Luxes con arquitectura hexagonal",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-notifications": "tsx prisma/seed-notifications.ts",
    "db:seed-ejemplo-recepcion": "tsx prisma/seed-ejemplo-recepcion.ts",
    "db:seed-ejemplo-instalacion": "tsx prisma/seed-ejemplo-instalacion.ts",
    "db:seed-nomina-demo": "tsx prisma/seed-nomina-demo.ts",
    "db:ensure-role-users": "tsx prisma/ensure-role-users.ts",
    "db:fix-inventory-categories": "tsx prisma/fix-inventory-categories.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
