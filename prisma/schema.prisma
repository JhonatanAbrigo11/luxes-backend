datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String        @id @default(uuid())
  nombre              String
  email               String        @unique
  username            String        @unique
  rol                 String        @default("visor")
  roleId              String?       @map("role_id")
  role                Role?         @relation(fields: [roleId], references: [id], onDelete: SetNull)
  estado              String        @default("activo")
  passwordHash        String        @map("password_hash")
  fechaCreacion       DateTime      @default(now()) @map("fecha_creacion")
  ultimoAcceso        DateTime?     @map("ultimo_acceso")
  sidebarConfig       String?       @map("sidebar_config")
  auditLogs           AuditLog[]
  prestamos           Prestamo[]
  ordenesCompra       OrdenCompra[]
  ordenesAprobadas    OrdenCompra[] @relation("OrdenAprobada")
  ordenesRecibidas    OrdenCompra[] @relation("OrdenRecibida")
  pushSubscriptions   PushSubscription[]
  tareasCreadas       Tarea[]           @relation("TareasCreadas")
  tareasAsignadas     TareaAsignacion[] @relation("TareasAsignadas")
  cierresCaja         CierreCaja[]
  empleadoId          String?       @unique @map("empleado_id")
  empleado            Empleado?     @relation(fields: [empleadoId], references: [id], onDelete: SetNull)

  @@index([roleId])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id    String           @id @default(uuid())
  key   String           @unique
  name  String
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid())
  fecha      DateTime @default(now())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  usuarioNom String?  @map("usuario_nom")
  accion     String
  modulo     String
  detalle    String
  severidad  String

  @@index([userId, fecha(sort: Desc)])
  @@map("audit_logs")
}

model Material {
  id            String                 @id @default(uuid())
  nombre        String
  tipo          String                 // "consumible" o "herramienta"
  unidadMedidaId String?               @map("unidad_medida_id")
  unidadMedida  UnidadMedida?          @relation(fields: [unidadMedidaId], references: [id], onDelete: SetNull)
  stockActual   Float                  @default(0) @map("stock_actual")
  stockMinimo   Float                  @default(0) @map("stock_minimo")
  precioCosto   Float                  @default(0) @map("precio_costo")
  fechaCreacion DateTime               @default(now()) @map("fecha_creacion")
  codigo        String?
  marca         String?
  modelo        String?
  serie         String?
  categoria     String?                @default("Taller") // "Taller" o "Oficina"
  estadoUso     String?                @default("BODEGA") @map("estado_uso") // "BODEGA", "EN USO", "NO SIRVE", "EN REPARACION"
  aCargo        String?                @map("a_cargo")
  ancho         Float?
  movimientos   MovimientoInventario[]
  prestamos     Prestamo[]
  detallesCompra DetalleCompra[]

  @@index([unidadMedidaId])
  @@map("materiales")
}

model UnidadMedida {
  id          String     @id @default(uuid())
  nombre      String     @unique
  abreviacion String?
  materiales  Material[]

  @@map("unidades_medida")
}

model MovimientoInventario {
  id         String   @id @default(uuid())
  materialId String   @map("material_id")
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  tipo       String   // "entrada" o "salida"
  cantidad   Float
  motivo     String
  fecha      DateTime @default(now())
  userId     String?  @map("user_id")

  @@index([materialId])
  @@map("movimientos_inventario")
}

model Prestamo {
  id            String    @id @default(uuid())
  materialId    String    @map("material_id")
  material      Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  responsableId String    @map("responsable_id")
  responsable   User      @relation(fields: [responsableId], references: [id], onDelete: Cascade)
  cantidad      Float     @default(1)
  fechaSalida   DateTime  @default(now()) @map("fecha_salida")
  fechaDevolucionEsperada DateTime? @map("fecha_devolucion_esperada") @db.Date
  fechaRetorno  DateTime? @map("fecha_retorno")
  comentarios   String?
  observacionDevolucion String? @map("observacion_devolucion")
  estado        String    @default("prestado") // "prestado" o "devuelto"

  @@index([materialId])
  @@index([responsableId])
  @@map("prestamos")
}

// ── Módulo de Compras ─────────────────────────────────────────────────────────

model Proveedor {
  id            String        @id @default(uuid())
  nombre        String
  ruc           String?       @unique
  tipo          String        @default("Empresa") // "Persona" | "Empresa"
  direccion     String?
  telefono      String?
  email         String?
  contacto      String?
  notas         String?
  estado        String        @default("activo")
  fechaCreacion DateTime      @default(now()) @map("fecha_creacion")
  ordenes       OrdenCompra[]

  @@map("proveedores")
}

model MetodoPago {
  id          String        @id @default(uuid())
  nombre      String        @unique
  descripcion String?
  activo      Boolean       @default(true)
  tipo        String        @default("EFECTIVO") // "EFECTIVO" o "BANCO"
  abonos      AbonoCompra[]
  gastos      Gasto[]
  proformas   Proforma[]
  abonosProforma AbonoProforma[]

  @@map("metodos_pago")
}

model OrdenCompra {
  id                String          @id @default(uuid())
  numero            String          @unique
  proveedorId       String?         @map("proveedor_id")
  proveedor         Proveedor?      @relation(fields: [proveedorId], references: [id])
  usuarioId         String          @map("usuario_id")
  usuario           User            @relation(fields: [usuarioId], references: [id])
  fecha             DateTime        @default(now())
  subtotal          Float           @default(0)
  impuesto          Float           @default(0)
  total             Float           @default(0)
  estado            String          @default("pendiente_aprobacion")
  estadoPago        String          @default("sin_pagar") @map("estado_pago")
  concepto          String?
  notas             String?
  fechaCreacion     DateTime        @default(now()) @map("fecha_creacion")
  fechaAprobacion   DateTime?       @map("fecha_aprobacion")
  aprobadoPorId     String?         @map("aprobado_por_id")
  aprobadoPor       User?           @relation("OrdenAprobada", fields: [aprobadoPorId], references: [id], onDelete: SetNull)
  fechaRecepcion    DateTime?       @map("fecha_recepcion")
  notasRecepcion    String?           @map("notas_recepcion")
  recibidoPorId     String?         @map("recibido_por_id")
  recibidoPor       User?           @relation("OrdenRecibida", fields: [recibidoPorId], references: [id], onDelete: SetNull)
  detalles          DetalleCompra[]
  abonos            AbonoCompra[]
  cuentaPorPagar    CuentaPorPagar?
  proyectoId        String?         @map("proyecto_id")
  proyecto          Proyecto?       @relation(fields: [proyectoId], references: [id], onDelete: SetNull)

  @@index([proveedorId])
  @@index([usuarioId])
  @@index([aprobadoPorId])
  @@index([recibidoPorId])
  @@index([proyectoId])
  @@map("ordenes_compra")
}

model DetalleCompra {
  id              String       @id @default(uuid())
  ordenCompraId   String       @map("orden_compra_id")
  ordenCompra     OrdenCompra  @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  materialId      String?      @map("material_id")
  material        Material?    @relation(fields: [materialId], references: [id], onDelete: SetNull)
  descripcion     String
  cantidad        Float
  precioUnitario  Float        @map("precio_unitario")
  subtotal        Float        @default(0)
  cantidadRecibida      Float?    @map("cantidad_recibida")
  descargableInventario Boolean?  @map("descargable_inventario")
  fechaRecepcion        DateTime? @map("fecha_recepcion")

  @@index([ordenCompraId])
  @@index([materialId])
  @@map("detalles_compra")
}

model AbonoCompra {
  id              String       @id @default(uuid())
  ordenCompraId   String       @map("orden_compra_id")
  ordenCompra     OrdenCompra  @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  metodoPagoId    String       @map("metodo_pago_id")
  metodoPago      MetodoPago   @relation(fields: [metodoPagoId], references: [id])
  monto           Float
  fecha           DateTime     @default(now())
  referencia      String?

  @@index([ordenCompraId])
  @@index([metodoPagoId])
  @@map("abonos_compra")
}

model CuentaPorPagar {
  id                String       @id @default(uuid())
  ordenCompraId     String       @unique @map("orden_compra_id")
  ordenCompra       OrdenCompra  @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  montoTotal        Float        @map("monto_total")
  montoPagado       Float        @default(0) @map("monto_pagado")
  saldo             Float        @default(0)
  fechaVencimiento  DateTime?    @map("fecha_vencimiento")
  estado            String       @default("pendiente")

  @@map("cuentas_por_pagar")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  rol       String?
  permission String?
  userId    String?  @map("user_id")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("fecha_creacion")

  @@index([userId])
  @@map("push_subscriptions")
}

// ── Módulo de Tareas ──────────────────────────────────────────────────────────

model Tarea {
  id                 String            @id @default(uuid())
  titulo             String
  descripcion        String?
  prioridad          String            @default("media") // "alta", "media", "baja"
  estado             String            @default("pendiente") // "pendiente", "en_progreso", "completada", "cancelada"
  fechaLimite        DateTime?         @map("fecha_limite")
  creadoPorId        String            @map("creado_por_id")
  creadoPor          User              @relation("TareasCreadas", fields: [creadoPorId], references: [id])
  fechaCreacion      DateTime          @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime?         @map("fecha_actualizacion")
  asignaciones       TareaAsignacion[]

  @@index([creadoPorId])
  @@map("tareas")
}

model TareaAsignacion {
  id      String @id @default(uuid())
  tareaId String @map("tarea_id")
  tarea   Tarea  @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation("TareasAsignadas", fields: [userId], references: [id])

  @@unique([tareaId, userId])
  @@map("tareas_asignaciones")
}

// ── Módulo de Empleados / Nómina ─────────────────────────────────────────────

model Empleado {
  id           String             @id
  nombre       String
  cedula       String             @unique
  cargo        String             @default("")
  departamento String             @default("")
  telefono     String             @default("")
  correo       String             @default("")
  cuentaBanco  String             @default("") @map("cuenta_banco")
  banco        String             @default("")
  tipoContrato String             @default("Fijo") @map("tipo_contrato")
  tieneContrato Boolean            @default(true) @map("tiene_contrato")
  region              String       @default("costa")
  decimoTerceroMensualizado Boolean @default(false) @map("decimo_tercero_mensualizado")
  decimoCuartoMensualizado  Boolean @default(false) @map("decimo_cuarto_mensualizado")
  sueldoDiario Decimal            @default(0) @map("sueldo_diario") @db.Decimal(10, 2)
  direccion    String             @default("")
  foto         String?
  passwordHash String             @default("") @map("password_hash")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  documentos   EmpleadoDocumento[]
  asistencias  Asistencia[]
  vacaciones   Vacacion[]
  horasExtras  HoraExtra[]
  nominas      NominaRegistro[]
  egresos      Egreso[]
  ingresosDetalles IngresoDetalle[]
  instalaciones ProyectoInstalacionPersonal[]
  user         User?

  @@map("empleados")
}

model EmpleadoDocumento {
  id         String   @id @default(uuid())
  empleadoId String   @map("empleado_id")
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tipo       String
  nombre     String
  archivoUrl String   @map("archivo_url")
  mimeType   String   @default("") @map("mime_type")
  tamano     Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([empleadoId, tipo])
  @@map("empleado_documentos")
}

model Asistencia {
  id            String   @id @default(uuid())
  empleadoId    String   @map("empleado_id")
  empleado      Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tipo          String
  label         String
  fechaHora     DateTime @map("fecha_hora")
  ubicacionLat  Float?   @map("ubicacion_lat")
  ubicacionLng  Float?   @map("ubicacion_lng")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([empleadoId, fechaHora])
  @@map("asistencias")
}

model Vacacion {
  id          String   @id @default(uuid())
  empleadoId  String   @map("empleado_id")
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  anio        Int
  diasTomados Json     @default("[]") @map("dias_tomados")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([empleadoId, anio])
  @@map("vacaciones")
}

model HoraExtra {
  id               String   @id @default(uuid())
  fecha            DateTime @db.Date
  colaboradorId    String   @map("colaborador_id")
  colaborador      Empleado @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  horas            Decimal  @db.Decimal(8, 2)
  detalleHorario   String   @default("") @map("detalle_horario")
  descripcion      String   @default("")
  valorPorHora     Decimal  @default(2.5) @map("valor_por_hora") @db.Decimal(10, 2)
  total            Decimal  @db.Decimal(10, 2)
  estado           String   @default("DEUDOR")
  aprobacionEstado String   @default("APROBADA") @map("aprobacion_estado")
  origen           String   @default("MANUAL")
  asistenciaFinId  String?  @map("asistencia_fin_id")

  @@index([colaboradorId, fecha])
  @@index([aprobacionEstado])
  @@map("horas_extras")
}

model NominaRegistro {
  id             String   @id @default(uuid())
  empleadoId     String   @map("empleado_id")
  empleado       Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fechaInicio    DateTime @map("fecha_inicio") @db.Date
  fechaFin       DateTime @map("fecha_fin") @db.Date
  diasLaborables Int      @default(30) @map("dias_laborables")
  diasLaborados  Int      @default(30) @map("dias_laborados")
  permisoHoras   Decimal  @default(0) @map("permiso_horas") @db.Decimal(8, 2)
  ingresos       Json     @default("{}")
  egresos        Json     @default("{}")
  abonos         Json     @default("[]")
  estado         String   @default("PENDIENTE")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([empleadoId, fechaInicio, fechaFin])
  @@map("nomina_registros")
}

model NominaPeriodoConfig {
  id          String   @id @default(uuid())
  fechaInicio DateTime @map("fecha_inicio") @db.Date
  fechaFin    DateTime @map("fecha_fin") @db.Date
  feriados    Json     @default("[]")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([fechaInicio, fechaFin])
  @@map("nomina_periodo_config")
}

model NominaConfigGlobal {
  id         String   @id @default("default")
  sbuVigente Decimal  @default(470) @map("sbu_vigente") @db.Decimal(10, 2)
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("nomina_config_global")
}

model Egreso {
  id           String   @id @default(uuid())
  empleadoId   String   @map("empleado_id")
  empleado     Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tipo         String   // "ANTICIPO" | "MULTA" | "OTROS"
  monto        Decimal  @db.Decimal(10, 2)
  fecha        DateTime @db.Date
  motivo       String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([empleadoId, fecha])
  @@map("egresos")
}

model IngresoDetalle {
  id           String   @id @default(uuid())
  empleadoId   String   @map("empleado_id")
  empleado     Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tipo         String   // "TRAB_EMP" | "OTROS"
  monto        Decimal  @db.Decimal(10, 2)
  fecha        DateTime @db.Date
  motivo       String   @default("")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([empleadoId, fecha])
  @@map("ingresos_detalles")
}

// ── Módulo de Clientes y Proformas ───────────────────────────────────────────

model Cliente {
  id        String     @id
  nombre    String
  cedulaRuc String     @default("") @map("cedula_ruc")
  telefono  String     @default("")
  email     String     @default("")
  direccion String     @default("")
  tipo      String     @default("Persona")
  notas     String     @default("")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  proformas Proforma[]
  proyectos Proyecto[]

  @@map("clientes")
}

model Proforma {
  id            String         @id
  clienteId     String?        @map("cliente_id")
  cliente       Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteNombre String         @map("cliente_nombre")
  telefono      String         @default("")
  email         String         @default("")
  fecha         DateTime       @db.Date
  vencimiento   DateTime?      @db.Date
  diasValidez   Int            @default(3) @map("dias_validez")
  atiende       String         @default("")
  condiciones   String         @default("")
  iva           Decimal        @default(0.12) @db.Decimal(6, 4)
  notas         String         @default("")
  estado        String         @default("Pendiente")
  metodoPagoId  String?        @map("metodo_pago_id")
  metodoPago    MetodoPago?    @relation(fields: [metodoPagoId], references: [id], onDelete: SetNull)
  fechaEnvio      DateTime?    @map("fecha_envio") @db.Date
  fechaAprobacion DateTime?    @map("fecha_aprobacion")
  creadoPorUserId String?      @map("creado_por_user_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  items         ProformaItem[]
  abonos        AbonoProforma[]

  @@index([clienteId])
  @@index([metodoPagoId])
  @@map("proformas")
}

// ── Configuración general de la empresa (singleton) ─────────────────────────────
model Configuracion {
  id                String   @id @default("default")
  condicionesPago   String   @default("") @map("condiciones_pago")
  celular           String   @default("")
  email             String   @default("")
  direccion         String   @default("")
  diasValidez       Int      @default(3) @map("dias_validez")
  horariosLaborales Json?    @map("horarios_laborales")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("configuracion")
}

model ProformaItem {
  id             String   @id @default(uuid())
  proformaId     String   @map("proforma_id")
  proforma       Proforma @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  descripcion    String
  cantidad       Decimal  @db.Decimal(12, 2)
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(12, 2)
  orden          Int      @default(0)

  @@index([proformaId])
  @@map("proforma_items")
}

model AbonoProforma {
  id            String     @id @default(uuid())
  proformaId    String     @map("proforma_id")
  proforma      Proforma   @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  metodoPagoId  String     @map("metodo_pago_id")
  metodoPago    MetodoPago @relation(fields: [metodoPagoId], references: [id])
  monto         Float
  fecha         DateTime   @default(now())
  referencia    String?

  @@index([proformaId])
  @@index([metodoPagoId])
  @@map("abonos_proforma")
}

// ── Módulo de Gastos ───────────────────────────────────────────────────────────

model Gasto {
  id             String                  @id
  concepto       String
  categoria      String                  @default("oficina")
  fecha          DateTime                @db.Date
  monto          Decimal                 @db.Decimal(12, 2)
  proveedor      String                  @default("")
  notas          String                  @default("")
  proyectoId     String?                 @map("proyecto_id")
  proyecto       Proyecto?               @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  mantenimientos VehiculoMantenimiento[]
  metodoPagoId   String?                 @map("metodo_pago_id")
  metodoPago     MetodoPago?             @relation(fields: [metodoPagoId], references: [id], onDelete: SetNull)
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  @@index([proyectoId])
  @@index([metodoPagoId])
  @@map("gastos")
}

model Vehiculo {
  id             String                  @id
  placa          String                  @unique
  marca          String                  @default("")
  modelo         String                  @default("")
  anio           Int?
  color          String                  @default("")
  kilometraje    Int                     @default(0)
  responsable    String                  @default("")
  notas          String                  @default("")
  estado         String                  @default("activo")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  mantenimientos VehiculoMantenimiento[]

  @@map("vehiculos")
}

model VehiculoMantenimiento {
  id             String    @id @default(uuid())
  vehiculoId     String    @map("vehiculo_id")
  vehiculo       Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  tipo           String
  descripcion    String    @default("")
  fechaRealizado DateTime  @map("fecha_realizado") @db.Date
  fechaProxima   DateTime? @map("fecha_proxima") @db.Date
  kilometraje    Int?
  kmProximo      Int?      @map("km_proximo")
  monto          Decimal   @default(0) @db.Decimal(12, 2)
  proveedor      String    @default("")
  notas          String    @default("")
  gastoId        String?   @map("gasto_id")
  gasto          Gasto?    @relation(fields: [gastoId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([vehiculoId, fechaRealizado])
  @@index([gastoId])
  @@map("vehiculo_mantenimientos")
}

// ── Módulo de Proyectos ───────────────────────────────────────────────────────

model Proyecto {
  id                     String            @id
  nombre                 String
  clienteId              String?           @map("cliente_id")
  cliente                Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteNombre          String            @default("") @map("cliente_nombre")
  clienteEmpresa         String            @default("") @map("cliente_empresa")
  clienteTelefono        String            @default("") @map("cliente_telefono")
  clienteEmail           String            @default("") @map("cliente_email")
  clienteDireccion       String            @default("") @map("cliente_direccion")
  responsable            String            @default("") // Nombre del responsable del proyecto
  requiereInstalacion    Boolean           @default(false) @map("requiere_instalacion")
  faseActual             String            @default("COTIZACION") @map("fase_actual") // COTIZACION, DISEÑO, PRODUCCION, INSTALACION, ENTREGA, COMPLETADO
  progreso               Int               @default(0) // 0-100
  prioridad              String            @default("MEDIA") // BAJA, MEDIA, ALTA, URGENTE
  estado                 String            @default("ACTIVO") // ACTIVO, PAUSADO, CANCELADO, COMPLETADO
  montoEstimado          Decimal           @default(0) @map("monto_estimado") @db.Decimal(12, 2)
  fechaCreacion          DateTime          @default(now()) @map("fecha_creacion")
  fechaEntregaEstimada   DateTime?         @map("fecha_entrega_estimada")
  fechaCompletado        DateTime?         @map("fecha_completado")
  descripcion            String            @default("")
  etiquetas              String            @default("") // JSON array de strings o separadas por coma
  notas                  String            @default("")
  
  // Relaciones
  fases                  ProyectoFase[]
  instalacion            ProyectoInstalacion?
  impresiones            ImpresionJob[]
  ordenesCompra          OrdenCompra[]
  gastos                 Gasto[]
  
  @@index([clienteId])
  @@map("proyectos")
}

model ProyectoFase {
  id                  String    @id @default(uuid())
  proyectoId          String    @map("proyecto_id")
  proyecto            Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  fase                String    // COTIZACION, DISEÑO, PRODUCCION, INSTALACION, ENTREGA, COMPLETADO
  completada          Boolean   @default(false)
  fechaCompletada     DateTime? @map("fecha_completada")
  datos               String    @default("{}") // JSON con datos específicos de la fase
  
  @@unique([proyectoId, fase])
  @@map("proyecto_fases")
}

model ProyectoInstalacion {
  id                     String                        @id @default(uuid())
  proyectoId             String                        @unique @map("proyecto_id")
  proyecto               Proyecto                      @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  fechaInstalacion       DateTime?                     @map("fecha_instalacion")
  direccionInstalacion   String                        @default("") @map("direccion_instalacion")
  notas                  String                        @default("")
  instalacionCompletada  Boolean                       @default(false) @map("instalacion_completada")
  notasCierre            String                        @default("") @map("notas_cierre")
  
  // Relaciones
  personalAsignado       ProyectoInstalacionPersonal[]
  materiales             ProyectoInstalacionMaterial[]
  
  @@map("proyecto_instalaciones")
}

model ProyectoInstalacionPersonal {
  id             String              @id @default(uuid())
  instalacionId  String              @map("instalacion_id")
  instalacion    ProyectoInstalacion @relation(fields: [instalacionId], references: [id], onDelete: Cascade)
  empleadoId     String              @map("empleado_id")
  empleado       Empleado            @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  rol            String              @default("") // Ej: "Instalador principal", "Ayudante"
  
  @@index([instalacionId])
  @@index([empleadoId])
  @@map("proyecto_instalacion_personal")
}

model ProyectoInstalacionMaterial {
  id             String              @id @default(uuid())
  instalacionId  String              @map("instalacion_id")
  instalacion    ProyectoInstalacion @relation(fields: [instalacionId], references: [id], onDelete: Cascade)
  nombre         String
  cantidad       Decimal             @db.Decimal(12, 2)
  unidad         String              @default("")
  observacion    String              @default("")
  
  @@index([instalacionId])
  @@map("proyecto_instalacion_materiales")
}

// ── Módulo de Impresiones / Cola de Impresión ───────────────────────────────

model ImpresionJob {
  id                Int       @id @default(autoincrement())
  name              String
  copies            Int       @default(1)
  responsible       String?
  status            String    @default("En espera") // "Listo", "Imprimiendo", "En espera", "Pausado", "Completado", "Cancelado"
  format            String    // Material/Sustrato
  elapsedSeconds    Int       @default(0) @map("elapsed_seconds")
  sentBy            String    @map("sent_by")
  sentAt            String    @map("sent_at")
  sentToQueueAt     String?   @map("sent_to_queue_at")
  startedPrintingAt String?   @map("started_printing_at")
  startTime         String?   @map("start_time")
  completedAt       String?   @map("completed_at")
  fileUrl           String?   @map("file_url")
  client            String
  urgency           String    @default("Media")
  width             Float     @default(1.0)
  height            Float     @default(1.0)
  notes             String    @default("")
  proyectoId        String?   @map("proyecto_id")
  proyectoNombre    String?   @map("proyecto_nombre")
  cancelReason      String?   @map("cancel_reason")
  position          Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at")

  // Relación con Proyecto opcional para poder navegar
  proyecto          Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@map("impresion_jobs")
}

model CierreCaja {
  id              String   @id @default(uuid())
  fecha           DateTime @default(now())
  fechaInicio     DateTime @map("fecha_inicio") @db.Date
  fechaFin        DateTime @map("fecha_fin") @db.Date
  totalIngresos   Decimal  @map("total_ingresos") @db.Decimal(12, 2)
  totalEgresos    Decimal  @map("total_egresos") @db.Decimal(12, 2)
  balance         Decimal  @db.Decimal(12, 2)
  metodosDetalle  String   @default("[]") @map("metodos_detalle") // JSON string con desglose por método de pago
  observaciones   String   @default("")
  usuarioId       String?  @map("usuario_id")
  usuario         User?    @relation(fields: [usuarioId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([usuarioId])
  @@map("cierres_caja")
}
